<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/frameLayout5"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    >

    <!-- TODO: Update blank fragment layout -->

    <TextView
        android:id="@+id/simple_toolbar"
        android:layout_width="match_parent"
        android:layout_height="57dp"
        android:background="@color/colorPeterRiver"
        android:gravity="center"
        android:text="视频"
        android:textColor="#FFFFFF"
        android:textSize="20sp" />

    <Button
        android:id="@+id/finish"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:text="finish"
        android:visibility="gone" />

    <RelativeLayout
        android:id="@+id/local_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/remotes"
        android:layout_width="match_parent"
        android:layout_height="260dp"
        android:layout_below="@+id/simple_toolbar"
        android:orientation="horizontal" />

    <TextView
        android:id="@+id/exchange_orientation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentRight="true"
        android:layout_alignParentBottom="true"
        android:padding="10dp"
        android:text="横竖屏切换"
        android:textColor="#FFFFFF" />

    <LinearLayout
        android:id="@+id/ll_set"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_below="@+id/remotes"
        android:background="@android:color/darker_gray"
        android:orientation="horizontal"
        android:visibility="gone">

        <ImageButton
            android:id="@+id/buttonPlay"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:colorAccent="@color/colorAmethyst"
            android:colorControlHighlight="@color/colorAmethyst"
            android:foreground="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_cam_play" />


        <ImageButton
            android:id="@+id/buttonMute"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:backgroundTint="@android:color/transparent"
            android:colorAccent="@color/colorAlizarin"
            android:colorControlHighlight="@color/colorAlizarin"
            android:src="@drawable/ic_cam_mute" />

        <ImageButton
            android:id="@+id/buttonVideo"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:backgroundTint="@android:color/transparent"
            android:src="@drawable/ic_cam_video" />

        <ImageButton
            android:id="@+id/buttonImage"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:foreground="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_cam_camera" />

        <ImageButton
            android:id="@+id/buttonFiles"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:foreground="?android:attr/selectableItemBackground"
            android:src="@drawable/ic_cam_folder" />

    </LinearLayout>

    <TextView
        android:id="@+id/listhead"
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:layout_below="@+id/ll_set"
        android:layout_margin="4dp"
        android:background="@color/colorCloudsLight"
        />

    <android.support.v7.widget.RecyclerView
        android:id="@+id/CarsList_recyclerview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/listhead" />

</RelativeLayout>
