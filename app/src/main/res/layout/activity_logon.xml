<?xml version="1.0" encoding="utf-8"?>
<android.support.constraint.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="cn.navibeidou.beidou.RegisterActivity">


    <cn.navibeidou.beidou.SimpleToolbar
        android:id="@+id/simple_toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="?android:attr/actionBarSize"
        app:contentInsetLeft="0dp"
        app:contentInsetStart="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/btn_corners"
        android:backgroundTint="@color/colorClouds"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/simple_toolbar">

        <android.support.constraint.ConstraintLayout
            android:id="@+id/ConstraintLayout1"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginStart="8dp"
            android:layout_marginTop="2dp"
            android:layout_marginEnd="8dp">

            <EditText
                android:id="@+id/editPhone"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="8dp"
                android:background="@null"
                android:ems="10"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:inputType="phone"
                android:textColor="@color/colorDarkGray"
                android:textColorHint="@color/colorConcrete"
                android:theme="@style/MyEditText"
                tools:ignore="MissingConstraints" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="2dp"
                android:background="#E0E0E6"
                app:layout_constraintBottom_toBottomOf="parent" />
        </android.support.constraint.ConstraintLayout>

        <android.support.constraint.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginStart="8dp"
            android:layout_marginTop="2dp"
            android:layout_marginEnd="8dp"
            android:visibility="gone">

            <EditText
                android:id="@+id/editD"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="2dp"
                android:background="@null"
                android:ems="10"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:inputType="text"
                android:textColor="@color/player_panel"
                android:textColorHint="@color/colorConcrete"
                android:textSize="10sp"
                android:theme="@style/MyEditText"
                tools:ignore="MissingConstraints" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="2dp"
                android:background="#E0E0E6"
                app:layout_constraintBottom_toBottomOf="parent" />
        </android.support.constraint.ConstraintLayout>

        <android.support.constraint.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginStart="8dp"
            android:layout_marginTop="2dp"
            android:layout_marginEnd="8dp"
            android:visibility="gone">

            <EditText
                android:id="@+id/editT"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="2dp"
                android:background="@null"
                android:ems="10"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:inputType="text"
                android:textColor="@color/player_panel"
                android:textColorHint="@color/colorConcrete"
                android:textSize="10sp"
                android:theme="@style/MyEditText"
                tools:ignore="MissingConstraints" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="2dp"
                android:background="#E0E0E6"
                app:layout_constraintBottom_toBottomOf="parent" />
        </android.support.constraint.ConstraintLayout>
        <!--<android.support.constraint.ConstraintLayout
            android:id="@+id/ConstraintLayout2"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginEnd="8dp"
            android:layout_marginStart="8dp"
            android:layout_marginTop="2dp">

            <EditText
                android:id="@+id/editSMS"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:background="@null"
                android:ems="10"
                android:hint="@string/smscode"
                android:inputType="number"
                android:textColor="@color/colorDarkGray"
                android:textColorHint="@color/colorConcrete"
                android:theme="@style/MyEditText"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <Button
                android:id="@+id/buttonSMS"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginEnd="10dp"
                android:background="@color/colorPeterRiver"
                android:foreground="?android:attr/selectableItemBackground"
                android:onClick="getSMSOnClick"
                android:text="@string/getsmscode"
                android:textColor="@drawable/btn_selector_text"
                app:layout_constraintEnd_toEndOf="parent" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="2dp"
                android:background="#E0E0E6"
                app:layout_constraintBottom_toBottomOf="parent" />

        </android.support.constraint.ConstraintLayout>-->

        <android.support.constraint.ConstraintLayout
            android:id="@+id/ConstraintLayout3"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginStart="8dp"
            android:layout_marginTop="2dp"
            android:layout_marginEnd="8dp">

            <EditText
                android:id="@+id/editPassword"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="2dp"
                android:background="@null"
                android:ems="10"
                android:inputType="textPassword"
                android:textColor="@color/colorDarkGray"
                android:textColorHint="@color/colorConcrete"
                android:theme="@style/MyEditText"
                tools:ignore="MissingConstraints" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="2dp"
                android:background="#E0E0E6"
                app:layout_constraintBottom_toBottomOf="parent" />
        </android.support.constraint.ConstraintLayout>

        <android.support.constraint.ConstraintLayout
            android:id="@+id/ConstraintLayout4"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginStart="8dp"
            android:layout_marginTop="2dp"
            android:layout_marginEnd="8dp">

            <EditText
                android:id="@+id/editPassword2"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="2dp"
                android:background="@null"
                android:ems="10"
                android:inputType="textPassword"
                android:textColor="@color/colorDarkGray"
                android:textColorHint="@color/colorConcrete"
                android:theme="@style/MyEditText"
                tools:ignore="MissingConstraints" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="2dp"
                android:background="#E0E0E6"
                app:layout_constraintBottom_toBottomOf="parent" />
        </android.support.constraint.ConstraintLayout>

        <Button
            android:id="@+id/buttonLogon"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="16dp"
            android:background="@color/colorPeterRiver"
            android:foreground="?android:attr/selectableItemBackground"
            android:gravity="center"
            android:onClick="LogonOnClick"
            android:textColor="@drawable/btn_selector_text"
            tools:layout_editor_absoluteX="5dp" />

    </LinearLayout>


</android.support.constraint.ConstraintLayout>
