<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">


    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <RelativeLayout
            android:id="@+id/frameLayout4"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

	            <com.amap.api.maps.MapView
	                android:id="@+id/map"
	                android:layout_width="match_parent"
	                android:layout_height="match_parent" />

		            <LinearLayout
		                android:layout_width="wrap_content"
		                android:layout_height="match_parent"
		                android:layout_alignParentRight="true"
	                android:layout_marginRight="12dp"
                android:clickable="true"
                android:gravity="center_vertical"
	                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_cloud_top"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:background="@color/transparent"
                    android:drawableTop="@drawable/ic_right_cloud"
                    android:drawablePadding="3dp"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:singleLine="true"
                    android:text="@string/home_cloud_panorama"
                    android:textColor="@color/black"
                    android:textSize="12sp" />

	                <TextView
	                    android:id="@+id/tv_poi"
	                    android:layout_width="wrap_content"
	                    android:layout_height="wrap_content"
	                    android:layout_gravity="center_horizontal"
	                    android:layout_marginTop="18dp"
	                    android:background="@color/transparent"
	                    android:drawableTop="@drawable/ic_right_search"
	                    android:gravity="center"
                    android:singleLine="true"
                    android:text="@string/find"
                    android:drawablePadding="3dp"
                    android:textColor="@color/black"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tv_weather"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="10dp"
                    android:background="@color/transparent"
                    android:drawableTop="@drawable/ic_right_weather"
                    android:gravity="center"
                    android:singleLine="true"
                    android:text="@string/weather"
                    android:drawablePadding="3dp"
                    android:textColor="@color/black"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tv_traffic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="10dp"
                    android:background="@color/transparent"
                    android:drawableTop="@drawable/ic_right_traffic"
                    android:gravity="center"
                    android:singleLine="true"
                    android:text="@string/road"
                    android:drawablePadding="3dp"
                    android:textColor="@color/black"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tv_vedio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="10dp"
                    android:background="@color/transparent"
                    android:drawableTop="@drawable/ic_right_bilingual"
                    android:gravity="center"
                    android:singleLine="true"
                    android:text="@string/zhen"
                    android:drawablePadding="3dp"
                    android:textColor="@color/black"
                    android:textSize="12sp"
                    android:visibility="visible" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_alignParentLeft="true"
                android:layout_marginLeft="17dp"
                android:clickable="true"
                android:gravity="center_vertical"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tv_world_panorama"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:background="@color/transparent"
                    android:drawableTop="@drawable/ic_world_panorama"
                    android:drawablePadding="4dp"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:singleLine="true"
                    android:text="@string/world_search_entry"
                    android:textColor="@color/black"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tv_quanjin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="10dp"
                    android:background="@color/transparent"
                    android:drawableTop="@mipmap/quanjing"
                    android:gravity="center"
                    android:singleLine="true"
                    android:text="@string/quanjing"
                    android:drawablePadding="3dp"
                    android:textColor="@color/black"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tv_metro"
                    android:layout_marginTop="10dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:background="@color/transparent"
                    android:drawableTop="@mipmap/metro"
                    android:gravity="center"
                    android:singleLine="true"
                    android:drawablePadding="3dp"
                    android:text="@string/metro"
                    android:textColor="@color/black"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tv_north"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="10dp"
                    android:drawablePadding="3dp"
                    android:background="@color/transparent"
                    android:drawableTop="@mipmap/north"
                    android:gravity="center"
                    android:singleLine="true"
                    android:text="@string/north"
                    android:textColor="@color/black"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/tv_game"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="10dp"
                    android:drawablePadding="3dp"
                    android:background="@color/transparent"
                    android:drawableTop="@mipmap/game"
                    android:gravity="center"
                    android:visibility="gone"
                    android:singleLine="true"
                    android:text="娱乐"
                    android:textColor="@color/black"
                    android:textSize="12sp" />

            </LinearLayout>
            <LinearLayout
                android:id="@+id/ll_bottom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:background="#efffffff"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/tab_explore"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingTop="2dp"
                    android:layout_marginLeft="12dp"
                    android:paddingBottom="16dp">

                    <ImageView
                        android:id="@+id/iv_tab_explore"
                        android:layout_width="60dp"
                        android:layout_height="30dp"
                        android:padding="5dp"
                        android:src="@drawable/ic_tab_explore" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/tab_explore"
                        android:textColor="#333333"
                        android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/tab_cloud"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingTop="2dp"
                    android:paddingBottom="16dp">

                    <ImageView
                        android:id="@+id/iv_tab_cloud"
                        android:layout_width="60dp"
                        android:layout_height="30dp"
                        android:padding="5dp"
                        android:src="@drawable/ic_cloud_panorama" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/tab_cloud_panorama"
                        android:textColor="#333333"
                        android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/tab_mine"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_marginRight="12dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="16dp">

                    <ImageView
                        android:id="@+id/iv_tab_mine"
                        android:layout_width="60dp"
                        android:layout_height="30dp"
                        android:padding="5dp"
                        android:src="@drawable/ic_tab_mine" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/tab_mine"
                        android:textColor="#333333"
                        android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>

            <RelativeLayout
                android:background="#7effffff"
	                android:id="@+id/search_bar_layout"
	                android:layout_width="match_parent"
	                android:layout_height="48dp"
		                android:layout_centerHorizontal="true"
		                android:layout_marginLeft="32dp"
		                android:layout_marginRight="32dp"
	                android:layout_marginTop="@dimen/offset_title"
	                android:clickable="true"
	                android:gravity="center_vertical"
	                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_centerVertical="true"
                    android:layout_toStartOf="@+id/btn_search"
                    android:layout_toLeftOf="@+id/btn_search"
                    android:background="@drawable/search_input_half"
                    android:clickable="true"
                    android:gravity="center_vertical">


                    <TextView
                        android:id="@+id/input_edittext"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@color/transparent"
                        android:drawableLeft="@drawable/search_input"
                        android:gravity="center_vertical"
                        android:paddingLeft="10dp"
                        android:text="@string/inputsearchplace"
                        android:singleLine="true"
                        android:drawablePadding="10dp"
                        android:textColor="#3a3a3a"
                        android:textColorHint="@color/darkgrey"
                        android:textSize="14sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/btn_search"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_alignParentEnd="true"
                    android:layout_alignParentRight="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/offlinearrow_tab2_pressed"
                    android:clickable="true"
                    android:gravity="center"
                    android:paddingStart="12dp"
                    android:paddingLeft="12dp"
                    android:paddingEnd="12dp"
                    android:paddingRight="12dp"
                    android:text="搜索"
                    android:textColor="@color/white"
                    android:textSize="12dp"
                    android:visibility="gone" />
            </RelativeLayout>

            <TextView
                android:id="@+id/tv_compass"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentRight="true"
                android:layout_alignParentBottom="true"
                android:layout_marginRight="12dp"
                android:layout_marginBottom="80dp"
                android:drawableTop="@drawable/compass"
                android:gravity="bottom"
                android:singleLine="true"
                android:textColor="@color/white"
	                android:textSize="12sp"
	                android:visibility="gone" />


        </RelativeLayout>

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_marginLeft="32dp"
            android:layout_marginRight="32dp"
            android:layout_height="48dp"
            android:layout_marginTop="115dp"
            android:background="#7effffff"
            android:visibility="visible"
            app:titleTextColor="#2a2a2a"
            app:titleTextAppearance="@style/AppTheme.locationTitle"
            app:title=""></androidx.appcompat.widget.Toolbar>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/menu_frame"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:visibility="visible">

        <include layout="@layout/left_menu" />
    </FrameLayout>

</androidx.drawerlayout.widget.DrawerLayout>
