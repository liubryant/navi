<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/page_header"
        android:layout_width="match_parent"
        android:layout_height="92dp"
        android:layout_alignParentTop="true"
        android:background="#F5F6F8"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:paddingTop="36dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_back_button"
            android:padding="9dp"
            android:scaleType="center"
            android:src="@drawable/ic_back_chevron" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/navi_start_end_poi_calculate_title"
            android:textColor="#222222"
            android:textSize="17sp"
            android:textStyle="bold" />

        <View
            android:layout_width="42dp"
            android:layout_height="42dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/page_header"
        android:orientation="vertical">

        <!-- 输入区域卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/input_card_bg"
            android:elevation="4dp"
            android:orientation="vertical"
            android:paddingLeft="8dp"
            android:paddingRight="6dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <!-- 我的位置行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:minHeight="32dp">

                <ImageView
                    android:id="@+id/iv_arrow"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:padding="2dp"
                    android:src="@mipmap/arrow"
                    android:tint="#666666"
                    android:visibility="gone" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginLeft="32dp"
                    android:src="@mipmap/dot_green" />

                <EditText
                    android:id="@+id/et_gps"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="8dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:focusable="false"
                    android:gravity="left|center_vertical"
                    android:text="我的位置"
                    android:textColor="#333333"
                    android:textSize="13sp"
                    android:padding="0dp" />
            </LinearLayout>

            <!-- 分隔线和中间按钮行 -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp"
                android:layout_marginBottom="0dp"
                android:gravity="center_vertical"
                android:minHeight="20dp">

                <View
                    android:layout_width="2dp"
                    android:layout_height="20dp"
                    android:visibility="gone"
                    android:layout_marginLeft="13dp"
                    android:background="#E0E0E0" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_centerVertical="true"
                    android:layout_marginLeft="32dp"
                    android:layout_marginRight="6dp"
                    android:layout_toLeftOf="@+id/plus"
                    android:background="#F0F0F0" />

                <ImageView
                    android:id="@+id/plus"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginRight="4dp"
                    android:layout_toLeftOf="@+id/change"
                    android:padding="6dp"
                    android:src="@mipmap/plus"
                    android:tint="#666666" />

                <ImageView
                    android:id="@+id/change"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_alignParentRight="true"
                    android:layout_marginRight="0dp"
                    android:padding="6dp"
                    android:src="@mipmap/change_up"
                    android:tint="#666666" />
            </RelativeLayout>

            <!-- 输入终点行 -->
            <LinearLayout
                android:id="@+id/ll_destination"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:minHeight="32dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginLeft="32dp"
                    android:src="@mipmap/dot_red" />

                <EditText
                    android:id="@+id/et_destination"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="8dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:focusable="false"
                    android:gravity="left|center_vertical"
                    android:hint="输入终点"
                    android:textColor="#333333"
                    android:textColorHint="#999999"
                    android:textSize="13sp"
                    android:padding="0dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- 分隔线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:visibility="gone"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:layout_marginBottom="8dp"
            android:background="#E8E8E8" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/margin_padding">

            <LinearLayout
                android:id="@+id/ll_drive"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:layout_weight="1"
                android:gravity="center">

                <Button
                    android:id="@+id/btn_drive"
                    android:layout_width="wrap_content"
                    android:layout_height="80dp"
                    android:padding="12dp"
                    android:background="@drawable/button_backgroud"
                    android:drawableTop="@drawable/amap_car"
                    android:gravity="center"
                    android:text="驾车"
                    android:textColor="@android:color/white"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_walk"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center">

                <Button
                    android:id="@+id/btn_walk"
                    android:layout_width="wrap_content"
                    android:layout_height="80dp"
                    android:padding="12dp"
                    android:layout_marginLeft="5dp"
                    android:background="@drawable/button_backgroud_grey"
                    android:drawableTop="@drawable/amap_man"
                    android:drawablePadding="3dp"
                    android:gravity="center"
                    android:text="步行"
                    android:textColor="#4D6486"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_bike"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center">

                <Button
                    android:id="@+id/btn_bike"
                    android:layout_width="wrap_content"
                    android:layout_height="80dp"
                    android:padding="12dp"
                    android:layout_marginLeft="5dp"
                    android:background="@drawable/button_backgroud_grey"
                    android:drawableTop="@drawable/amap_ride"
                    android:drawablePadding="3dp"
                    android:gravity="center"
                    android:text="骑行"
                    android:textColor="#4D6486"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_truck"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginRight="20dp"
                android:layout_weight="1"
                android:gravity="center">

                <Button
                    android:id="@+id/btn_truck"
                    android:layout_width="wrap_content"
                    android:layout_height="80dp"
                    android:padding="12dp"
                    android:layout_marginLeft="5dp"
                    android:background="@drawable/button_backgroud_grey"
                    android:drawableTop="@drawable/amap_truck"
                    android:drawablePadding="3dp"
                    android:gravity="center"
                    android:text="货车"
                    android:textColor="#4D6486"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/margin_padding">

            <Button
                android:id="@+id/btn_near"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_marginLeft="20dp"
                android:layout_weight="1"
                android:background="@drawable/button_backgroud"
                android:gravity="center"
                android:text="附近街景"
                android:textColor="@android:color/white"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btn_navi"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="20dp"
                android:layout_weight="1"
                android:background="@drawable/button_backgroud"
                android:gravity="center"
                android:text="开始导航"
                android:textColor="@android:color/white"
                android:textSize="14sp" />
        </LinearLayout>

        <ListView
            android:id="@+id/list"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:visibility="gone" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true">

        <FrameLayout
            android:id="@+id/express_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:background="#ffffff" />
    </ScrollView>
</RelativeLayout>
