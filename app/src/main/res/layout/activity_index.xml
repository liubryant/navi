<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="50dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/iv_arrow"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginLeft="20dp"
                android:gravity="center"
                android:src="@mipmap/arrow" />

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginLeft="19dp"
                android:gravity="center"
                android:src="@mipmap/dot_green" />

            <EditText
                android:id="@+id/et_gps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:background="@color/white"
                android:focusable="false"
                android:gravity="left"
                android:text="我的位置"
                android:textColor="@android:color/black"
                android:textSize="14sp" />
        </LinearLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginLeft="12dp"
                android:gravity="center"
                android:src="@mipmap/bg_dot" />

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_centerVertical="true"
                android:layout_marginLeft="40dp"
                android:layout_marginRight="10dp"
                android:layout_toLeftOf="@+id/plus"
                android:background="@color/grey"
                android:gravity="center" />

            <ImageView
                android:id="@+id/plus"
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:layout_marginRight="10dp"
                android:layout_toLeftOf="@+id/change"
                android:gravity="center"
                android:src="@mipmap/plus" />

            <ImageView
                android:id="@+id/change"
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:layout_alignParentRight="true"
                android:layout_marginRight="20dp"
                android:gravity="center"
                android:src="@mipmap/change_up" />
        </RelativeLayout>

        <LinearLayout
            android:id="@+id/ll_destination"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginLeft="70dp"
                android:gravity="center"
                android:src="@mipmap/dot_red" />

            <EditText
                android:id="@+id/et_destination"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:background="@color/white"
                android:focusable="false"
                android:gravity="left"
                android:hint="输入终点"
                android:textColor="@android:color/black"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/margin_padding">

            <LinearLayout
                android:id="@+id/ll_drive"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:layout_weight="1"
                android:gravity="center">

                <Button
                    android:id="@+id/btn_drive"
                    android:layout_width="wrap_content"
                    android:layout_height="70dp"
                    android:padding="4dp"
                    android:background="@drawable/button_backgroud"
                    android:drawableTop="@drawable/amap_car"
                    android:gravity="center"
                    android:text="驾车"
                    android:textColor="@android:color/white"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_walk"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center">

                <Button
                    android:id="@+id/btn_walk"
                    android:layout_width="wrap_content"
                    android:layout_height="70dp"
                    android:padding="4dp"
                    android:layout_marginLeft="5dp"
                    android:background="@drawable/button_backgroud_grey"
                    android:drawableTop="@drawable/amap_man"
                    android:drawablePadding="3dp"
                    android:gravity="center"
                    android:text="步行"
                    android:textColor="#4D6486"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_bike"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center">

                <Button
                    android:id="@+id/btn_bike"
                    android:layout_width="wrap_content"
                    android:layout_height="70dp"
                    android:padding="4dp"
                    android:layout_marginLeft="5dp"
                    android:background="@drawable/button_backgroud_grey"
                    android:drawableTop="@drawable/amap_ride"
                    android:drawablePadding="3dp"
                    android:gravity="center"
                    android:text="骑行"
                    android:textColor="#4D6486"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_truck"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginRight="20dp"
                android:layout_weight="1"
                android:gravity="center">

                <Button
                    android:id="@+id/btn_truck"
                    android:layout_width="wrap_content"
                    android:layout_height="70dp"
                    android:padding="4dp"
                    android:layout_marginLeft="5dp"
                    android:background="@drawable/button_backgroud_grey"
                    android:drawableTop="@drawable/amap_truck"
                    android:drawablePadding="3dp"
                    android:gravity="center"
                    android:text="货车"
                    android:textColor="#4D6486"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/margin_padding">

            <Button
                android:id="@+id/btn_near"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginLeft="20dp"
                android:layout_weight="1"
                android:background="@drawable/button_backgroud"
                android:gravity="center"
                android:text="附近街景"
                android:textColor="@android:color/white"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btn_navi"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="20dp"
                android:layout_weight="1"
                android:background="@drawable/button_backgroud"
                android:gravity="center"
                android:text="开始导航"
                android:textColor="@android:color/white"
                android:textSize="14sp" />
        </LinearLayout>

        <ListView
            android:id="@+id/list"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:visibility="gone" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true">

        <FrameLayout
            android:id="@+id/express_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:background="#ffffff" />
    </ScrollView>
</RelativeLayout>
