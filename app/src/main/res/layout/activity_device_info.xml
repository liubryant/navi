<?xml version="1.0" encoding="utf-8"?>
<android.support.constraint.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="cn.navibeidou.beidou.DeviceInfoActivity">


    <cn.navibeidou.beidou.SimpleToolbar
        android:id="@+id/simple_toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="?android:attr/actionBarSize"
        app:contentInsetLeft="0dp"
        app:contentInsetStart="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <EditText
        android:id="@+id/editIMEI"
        android:layout_width="300dp"
        android:layout_height="50dp"
        android:layout_marginTop="8dp"
        android:ems="10"
        android:inputType="text"
        android:textColor="@android:color/darker_gray"
        android:textColorHint="@color/colorConcrete"
        android:theme="@style/MyEditText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/simple_toolbar" />

    <EditText
        android:id="@+id/editISBN"
        android:layout_width="300dp"
        android:layout_height="50dp"
        android:layout_marginTop="2dp"
        android:ems="10"
        android:inputType="text"
        android:textColor="@android:color/black"
        android:textColorHint="@color/colorConcrete"
        android:theme="@style/MyEditText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/editIMEI" />

    <EditText
        android:id="@+id/editsisNum"
        android:layout_width="300dp"
        android:layout_height="54dp"
        android:layout_marginTop="2dp"
        android:ems="10"
        android:inputType="text"
        android:textColor="@android:color/black"
        android:textColorHint="@color/colorConcrete"
        android:theme="@style/MyEditText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/editISBN" />

    <EditText
        android:id="@+id/editVIN"
        android:layout_width="300dp"
        android:layout_height="50dp"
        android:layout_marginTop="2dp"
        android:ems="10"
        android:inputType="text"
        android:textColor="@android:color/black"
        android:textColorHint="@color/colorConcrete"
        android:theme="@style/MyEditText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/editsisNum" />

    <EditText
        android:id="@+id/editCarphone"
        android:layout_width="300dp"
        android:layout_height="50dp"
        android:layout_marginTop="2dp"
        android:ems="10"
        android:inputType="phone"
        android:textColor="@android:color/black"
        android:textColorHint="@color/colorConcrete"
        android:theme="@style/MyEditText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/editVIN" />

    <Button
        android:id="@+id/buttonEdit"
        android:layout_width="300dp"
        android:layout_height="50dp"
        android:layout_margin="5dip"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:background="@drawable/border_line_while"
        android:gravity="center"
        android:text="确认修改"
        android:textColor="@color/colorPeterRiver"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/editCarphone" />
    <Button
        android:id="@+id/buttonAdd"
        android:layout_width="300dp"
        android:layout_height="50dp"
        android:layout_margin="5dip"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:background="@drawable/border_line_while"
        android:gravity="center"
        android:text="增加+"
        android:textColor="@color/colorPeterRiver"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/buttonEdit" />

    <Button
        android:id="@+id/buttonDelete"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/btn_selector"
        android:backgroundTint="@color/colorPeterRiver"
        android:text="删除"
        android:textColor="@drawable/btn_selector_text"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />


</android.support.constraint.ConstraintLayout>
