<?xml version="1.0" encoding="utf-8"?>
<android.support.constraint.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="cn.navibeidou.beidou.DeviceInfoActivity">


    <cn.navibeidou.beidou.SimpleToolbar
        android:id="@+id/simple_toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="?android:attr/actionBarSize"
        app:contentInsetLeft="0dp"
        app:contentInsetStart="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <EditText
        android:id="@+id/editIMEI"
        android:layout_width="300dp"
        android:layout_height="50dp"
        android:layout_marginTop="8dp"
        android:ems="10"
        android:inputType="text"
        android:textColor="@android:color/darker_gray"
        android:textColorHint="@color/colorConcrete"
        android:theme="@style/MyEditText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/simple_toolbar" />

    <EditText
        android:id="@+id/editDeviceName"
        android:layout_width="300dp"
        android:layout_height="50dp"
        android:layout_marginTop="8dp"
        android:ems="10"
        android:inputType="text"
        android:textColor="@android:color/darker_gray"
        android:textColorHint="@color/colorConcrete"
        android:theme="@style/MyEditText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/editIMEI" />

    <EditText
        android:id="@+id/editD"
        android:layout_width="300dp"
        android:layout_height="50dp"
        android:layout_marginTop="2dp"
        android:ems="10"
        android:hint="d"
        android:inputType="text"
        android:textColor="@android:color/darker_gray"
        android:textColorHint="@color/colorConcrete"
        android:textSize="11sp"
        android:theme="@style/MyEditText"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/editDeviceName" />

    <EditText
        android:id="@+id/editT"
        android:layout_width="300dp"
        android:layout_height="54dp"
        android:layout_marginTop="2dp"
        android:ems="10"
        android:hint="t"
        android:inputType="text"
        android:textColor="@android:color/darker_gray"
        android:textColorHint="@color/colorConcrete"
        android:textSize="11sp"
        android:theme="@style/MyEditText"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/editD" />

    <EditText
        android:id="@+id/editVIN"
        android:layout_width="300dp"
        android:layout_height="50dp"
        android:layout_marginTop="2dp"
        android:ems="10"
        android:inputType="text"
        android:textColor="@android:color/black"
        android:textColorHint="@color/colorConcrete"
        android:theme="@style/MyEditText"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/editT" />

    <EditText
        android:id="@+id/editCarphone"
        android:layout_width="300dp"
        android:layout_height="50dp"
        android:layout_marginTop="2dp"
        android:ems="10"
        android:inputType="phone"
        android:textColor="@android:color/black"
        android:textColorHint="@color/colorConcrete"
        android:theme="@style/MyEditText"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/editVIN" />

    <Button
        android:id="@+id/buttonEdit"
        android:layout_width="300dp"
        android:layout_height="50dp"
        android:layout_margin="5dip"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:background="@drawable/border_line_while"
        android:gravity="center"
        android:onClick="bindDevice"
        android:visibility="gone"
        android:text="确认修改"
        android:textColor="@color/colorPeterRiver"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/editCarphone"
        tools:ignore="OnClick" />

    <Button
        android:id="@+id/buttonAdd"
        android:layout_width="300dp"
        android:layout_height="50dp"
        android:layout_margin="5dip"
        android:layout_marginTop="20dp"
        android:layout_weight="1"
        android:gravity="center"
        android:onClick="addDevice"
        android:text="新增+"


        android:background="@drawable/btn_selector"
        android:backgroundTint="@color/colorPeterRiver"
        android:textColor="@drawable/btn_selector_text"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/buttonEdit"
        tools:ignore="OnClick" />

    <Button
        android:id="@+id/buttonDelete"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/btn_selector"
        android:backgroundTint="@color/colorPeterRiver"
        android:onClick="unbindDevice"
        android:text="删除"
        android:textColor="@drawable/btn_selector_text"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:ignore="OnClick" />

    <TextView
        android:id="@+id/tv_select"
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:layout_below="@+id/ll_set"
        android:layout_marginTop="60dp"
        android:background="@color/colorCloudsLight"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/buttonAdd" />

    <android.support.v7.widget.RecyclerView
        android:id="@+id/CarsList_recyclerview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/listhead"
        android:layout_marginTop="25dp"
        android:visibility="visible"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tv_select" />

</android.support.constraint.ConstraintLayout>
